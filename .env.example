# Hoop Higher configuration

# Provider options:
# - nba_api: real NBA data with SQLite-backed cache (default)
# - mock: local deterministic data for development and tests
HOOPHIGHER_STATS_PROVIDER=nba_api

# SQLite database URL.
HOOPHIGHER_DATABASE_URL=sqlite:///var/hoophigher.db

# SQLite pragmas. Leave blank to use SQLite defaults.
HOOPHIGHER_SQLITE_JOURNAL_MODE=WAL
HOOPHIGHER_SQLITE_SYNCHRONOUS=NORMAL
HOOPHIGHER_SQLITE_BUSY_TIMEOUT_MS=5000

# Historical mode date index and run length.
HOOPHIGHER_HISTORICAL_START_YEAR=2010
HOOPHIGHER_HISTORICAL_END_YEAR=2020
HOOPHIGHER_HISTORICAL_ROUNDS=5

# Timeout, in seconds, for nba_api scoreboard and boxscore requests.
HOOPHIGHER_NBA_API_TIMEOUT_SECONDS=20

# Number of retry attempts after the initial nba_api request fails.
HOOPHIGHER_NBA_API_MAX_RETRIES=1

# Base delay in seconds between retries (multiplied by attempt number).
HOOPHIGHER_NBA_API_RETRY_DELAY_SECONDS=1.0

# Maximum concurrent API requests to stats.nba.com.
HOOPHIGHER_NBA_API_FETCH_CONCURRENCY=5

# Number of real-api non-historical games to fetch before opening gameplay.
HOOPHIGHER_NBA_API_STARTUP_GAMES=5

# Maximum total wait, in seconds, before returning to the mode picker.
HOOPHIGHER_GAME_START_TIMEOUT_SECONDS=45

# Maximum random dates to probe before giving up in historical mode.
HOOPHIGHER_HISTORICAL_MAX_DATE_PROBES=10
